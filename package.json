{
  "name": "high-traffic-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev:safe -w apps/api",
    "dev:client": "npm run dev -w apps/client",
    "dev:admin": "npm run dev -w apps/admin",
    "dev": "concurrently -c \"yellow,blue,magenta\" --names \"BACKEND,CLIENT,ADMIN\" --handle-input \"npm run dev:api\" \"npm run dev:client\" \"npm run dev:admin\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0"
  }
}
